# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=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

# ── Models ────────────────────────────────────────────────────────────────────
# Haiku 4.5 for search-heavy agents (cheaper ~$1/$5 per 1M tokens)
ANALYST_MODEL=claude-haiku-4-5-20251001
NEWS_MODEL=claude-haiku-4-5-20251001
# Sonnet 4.6 for the Portfolio Manager (better reasoning, ~$3/$15 per 1M tokens)
PM_MODEL=claude-sonnet-4-6

# ── Portfolio ─────────────────────────────────────────────────────────────────
STARTING_CAPITAL=1000
# On Railway: set to /data/portfolio.json and add a Volume mounted at /data
# On Render:  set to /data/portfolio.json and add a Disk mounted at /data
PORTFOLIO_FILE=portfolio.json
# Minimum cash to keep in reserve (10% = 0.10)
CASH_BUFFER_PCT=0.10

# ── Schedule (AEST, 24-hour, comma-separated) ─────────────────────────────────
# Default: 10am, 12pm, 2pm Mon–Fri (ASX market hours)
CYCLE_HOURS=10,11,12,13,14,15
# Run a cycle immediately on startup if the market is currently open
RUN_ON_STARTUP=true

# ── API Security ──────────────────────────────────────────────────────────────
# Protects the POST /api/trigger endpoint. Set to a long random string.
# Leave blank to allow unauthenticated manual triggers (not recommended).
DAEDALUS_API_KEY=

# ── Trade Execution ───────────────────────────────────────────────────────────
# false (safe default): PM recommendations are emailed for manual review.
#                       Pending trades appear in the dashboard for approval.
# true:                 HIGH-confidence trades are executed automatically.
AUTO_APPROVE_TRADES=true
AUTO_APPROVE_MIN_CONFIDENCE=HIGH

# ── Email Notifications (optional, Gmail) ────────────────────────────────────
# Recipient — where cycle reports are sent
NOTIFY_EMAIL=your@email.com.au
# Your Gmail address used to send
SMTP_USER=your_gmail@gmail.com
# Gmail App Password (NOT your login password).
# Create one at: Google Account → Security → 2-Step Verification → App Passwords
SMTP_PASS=your_16_char_app_password
