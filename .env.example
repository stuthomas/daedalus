# ── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key. Never commit a real key — set this in Railway Variables.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Models ────────────────────────────────────────────────────────────────────
# Haiku 4.5 for the search-heavy agents (cheap, fast).
ANALYST_MODEL=claude-haiku-4-5
NEWS_MODEL=claude-haiku-4-5
# Opus 4.8 for the Portfolio Manager (most capable — the reasoning-critical agent).
PM_MODEL=claude-opus-4-8

# ── Portfolio ─────────────────────────────────────────────────────────────────
STARTING_CAPITAL=1000
# On Railway: set to /data/portfolio.json and add a Volume mounted at /data so the
# portfolio/status SURVIVES redeploys. Code deploys never touch the Volume, and
# older portfolios are migrated automatically (new fields are added on load).
PORTFOLIO_FILE=portfolio.json
# Minimum cash to keep in reserve (10% = 0.10)
CASH_BUFFER_PCT=0.10

# ── Risk Management ──────────────────────────────────────────────────────────
# Stop-loss: auto-sell if a position drops this % from avg buy price (6% = 0.06)
STOP_LOSS_PCT=0.06
# Trailing stop: auto-sell if price drops this % from its PEAK price (locks in gains)
TRAILING_STOP_PCT=0.10
# Take-profit: when a position is up this %, auto-trim part of it (see below)
TAKE_PROFIT_PCT=0.25
# Fraction of the position sold when take-profit fires (0.5 = sell half)
TAKE_PROFIT_TRIM_PCT=0.5
# Max single position as % of portfolio
MAX_POSITION_PCT=0.25
# Max single sector as % of portfolio
MAX_SECTOR_PCT=0.40
# NO SMALL INCREMENTS: every agent BUY must be at least the GREATER of this dollar
# floor and MIN_TRADE_PCT of the whole book, so trades stay meaningful and the
# floor scales as the account grows. Manual trades are exempt.
MIN_TRADE_VALUE=150
MIN_TRADE_PCT=0.08
# Pending trades auto-expire after this many hours (only relevant if you raise the
# auto-approve threshold below — by default nothing is left pending)
PENDING_TRADE_EXPIRY_HOURS=8

# ── Market Regime ────────────────────────────────────────────────────────────
# Yahoo Finance symbol used for the ASX market-regime read (^AXJO = ASX 200)
ASX_INDEX_SYMBOL=^AXJO

# ── Schedule (AEST, 24-hour, comma-separated) ─────────────────────────────────
# Default: 10am, 12pm, 2pm Mon–Fri (ASX market hours)
CYCLE_HOURS=10,12,14
# Run a cycle immediately on startup if the market is currently open
RUN_ON_STARTUP=true

# ── Trade Execution ───────────────────────────────────────────────────────────
# Fully autonomous by default: execute EVERY trade the Portfolio Manager decides
# (no approvals) so the paper portfolio runs and grows on its own, within all the
# risk limits above. Raise AUTO_APPROVE_MIN_CONFIDENCE to MEDIUM or HIGH to route
# weaker trades to the dashboard's approve/reject panel instead.
AUTO_APPROVE_TRADES=true
AUTO_APPROVE_MIN_CONFIDENCE=LOW

# ── API Security ──────────────────────────────────────────────────────────────
# Protects POST endpoints (/api/trigger, approve/reject). Set to a long random
# string in Railway. The dashboard is served by the daemon at / (same origin);
# GET endpoints are open, POSTs require this key (put it in the dashboard Settings).
DAEDALUS_API_KEY=
